# ---------------------------------------------------------------------------
# Internal Documentation MCP Server — example configuration.
# Copy to .env (kept out of VCS) and adjust. All values are read at startup.
# ---------------------------------------------------------------------------

# Curated Markdown doc store: written by ingestion, read by the server.
DOC_ROOT=/srv/docs/curated

# Comma-separated raw source roots fed to the ingestion pipeline.
SOURCE_DIRS=/srv/docs/raw

# Bind to localhost only; TLS is terminated by the reverse proxy (see README).
# Inside Docker the server binds 0.0.0.0 but the port is not published — only
# the reverse proxy reaches it over the compose network.
BIND_HOST=127.0.0.1
BIND_PORT=8080

# token -> {user, allowed_prefixes}. Treat as a secret (file perms; not in VCS).
TOKENS_FILE=/srv/docs/tokens.json

# Keyword search backend: ripgrep | fts5
SEARCH_BACKEND=ripgrep
# SQLite FTS5 database (used when SEARCH_BACKEND=fts5; built during ingestion).
FTS5_DB=/srv/docs/index.sqlite

# Optional vector layer — OFF by default. When false, Qdrant/OpenAI are never
# contacted and src/docmcp/search/vector.py is never imported at request time.
ENABLE_VECTOR=false
QDRANT_URL=http://qdrant:6333
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
EMBED_CHUNK_TOKENS=512

# --- HTTP transport hardening (DNS-rebinding protection) ---
# Comma-separated allowed Origin header values. A request that carries an Origin
# NOT in this list is rejected (403). Requests with no Origin (typical for CLI
# MCP clients like Codex) are allowed. Empty list => reject any present Origin.
ALLOWED_ORIGINS=
# Comma-separated Host header allowlist (TrustedHostMiddleware). In production
# include the public hostname the reverse proxy serves, e.g. docs-mcp.company.internal.
ALLOWED_HOSTS=localhost,127.0.0.1

# Offline Docling model artifacts (set on the ingestion host / image). Point at
# the PARENT dir holding the downloaded model repos (see README air-gapped notes).
# DOCLING_ARTIFACTS_PATH=/opt/docling/models
