# ---------------------------------------------------------------------------
# Documentation MCP Server — example configuration.
# Copy to .env (kept out of VCS) and adjust. All values are read at startup.
# ---------------------------------------------------------------------------

# Curated Markdown doc store: written by ingestion, read by the server.
# DOC_ROOT holds ONLY the served docs.
DOC_ROOT=/srv/docs/curated

# Where internal/derived files live (index, manifest, ingest-status, lock, FTS5 db) —
# OUTSIDE DOC_ROOT so they can't be read_doc'd. Defaults to DOC_ROOT's parent; DOC_ROOT
# must be a strict subdirectory of it. Usually leave unset.
# DOCSTORE_ROOT=/srv/docs

# Comma-separated raw source roots fed to the ingestion pipeline.
SOURCE_DIRS=/srv/docs/raw

# Parallel ingest: how many worker processes parse files at once. The slow step is
# Docling (PDF/Office/image OCR) + tree-sitter. `docmcp.sh ingest` auto-sizes this from
# the Docker VM's real CPU + RAM when unset (≈1 worker per 3 vCPUs and per 3 GiB, so it
# scales on a server but never OOMs a small VM), and pins each worker's math threads to
# vCPUs/workers. Set explicitly to tune: 1 = sequential; raise on a big box with spare
# RAM (each best-quality worker can peak at several GB). Range 1–64.
# INGEST_WORKERS=2

# App listener for the BARE / uv dev run only (`uv run docmcp-server`).
# NOTE: on the Docker path these are PINNED by docker/docker-compose.yml
# (BIND_HOST=0.0.0.0, BIND_PORT=8080, internal-only / not published) and editing
# them here has NO effect on the container. To change the CLIENT-facing port on
# Docker use HTTP_PORT (see the Network exposure section below), not BIND_PORT.
BIND_HOST=127.0.0.1
BIND_PORT=8080

# token -> {user, allowed_prefixes}. Treat as a secret (file perms; not in VCS).
TOKENS_FILE=/srv/docs/tokens.json

# Keyword search backend: ripgrep | fts5
SEARCH_BACKEND=ripgrep
# SQLite FTS5 database (used when SEARCH_BACKEND=fts5; built during ingestion).
FTS5_DB=/srv/docs/index.sqlite

# Structured access log: one JSON line per tool call to stderr (user, tool, prefix
# count, path, result size, ms — never the token or doc content). Set false to silence.
# LOG_REQUESTS=true

# ---- Upload/manage portal (OPTIONAL write surface; OFF by default) ----
# Enable a browser portal where tokens minted with `--write <prefix>` can upload/manage
# docs into raw/. It writes ONLY to raw/; the cron `schedule` ingests. docs-mcp stays
# read-only. Reach it at <server>/portal (via Caddy). See docs/PORTAL.md.
# PORTAL_ENABLED=false
# SESSION_SECRET=<auto-generated by ./docmcp.sh setup>   # HMAC key for session cookies
# ALLOW_PLAINTEXT_PORTAL=true   # REQUIRED to serve the portal without TLS (session cookies
#                               # travel in cleartext — trusted/VPN networks only). For a
#                               # public network set DOMAIN=<host> for HTTPS instead.
# MAX_UPLOAD_BYTES=26214400     # 25 MiB per file ; MAX_UPLOAD_FILES=20

# Optional vector layer — OFF by default. When false, Qdrant is never contacted and
# src/docmcp/search/vector.py is never imported at request time. Qdrant runs as a local
# container (on-prem; no external API).
ENABLE_VECTOR=false
QDRANT_URL=http://qdrant:6333
EMBED_CHUNK_TOKENS=512

# Embedding backend for semantic search.
#   local  (default) — a vendored ONNX model run in-process via onnxruntime + tokenizers,
#                      FULLY OFFLINE (no network) — required for air-gapped deployments.
#                      Ships bge-small-en-v1.5 (English, 384-dim, CLS pooling). Switching
#                      the backend/dim/model requires a full re-ingest (the Qdrant
#                      collection is rebuilt at the new vector size).
#   openai           — legacy ONLINE API (external calls). Install `.[vector,vector-openai]`
#                      and set OPENAI_API_KEY. NOT usable in an air-gapped/no-API deployment.
EMBED_BACKEND=local
# The model-intrinsic settings below are BAKED INTO THE IMAGE for the shipped bge model, so
# you normally leave them unset. Override only if you vendor a different model — and QUOTE
# any value containing spaces (this file is also sourced by the shell):
# EMBED_MODEL_DIR=/opt/models/embed
# EMBED_DIM=384
# EMBED_POOLING=cls            # cls (bge) | mean (MiniLM/e5)
# EMBED_QUERY_PREFIX="Represent this sentence for searching relevant passages: "
# EMBED_PASSAGE_PREFIX=""
# Legacy online backend only (EMBED_BACKEND=openai):
# OPENAI_API_KEY=
# OPENAI_EMBED_MODEL=text-embedding-3-small

# --- HTTP transport hardening (DNS-rebinding protection) ---
# Comma-separated allowed Origin header values. A request that carries an Origin
# NOT in this list is rejected (403). Requests with no Origin (typical for CLI
# MCP clients like Codex) are allowed. Empty list => reject any present Origin.
ALLOWED_ORIGINS=
# Comma-separated Host header allowlist (TrustedHostMiddleware). Must include the
# address clients put in the URL — host/IP ONLY (any :port is stripped before
# matching, so do NOT add a port). An EMPTY value disables the host check entirely.
# For the default internal-network (VPN, raw IP) setup add the server's IP; for the
# HTTPS profile add that hostname instead.
# Replace 10.0.0.5 below with your server's VPN/LAN IP (keep this on its own line —
# do NOT put an inline `# comment` after the value; the env parser may keep it).
ALLOWED_HOSTS=10.0.0.5,localhost,127.0.0.1

# --- Network exposure (Docker reverse proxy) ---
# Pick ONE profile. The server is reached at  http(s)://<host-or-ip>/mcp  via Caddy.
#
# [DEFAULT — safe] Single machine / loopback. As shipped (HTTP_BIND and
#   ALLOW_PLAINTEXT_HTTP left COMMENTED OUT below), HTTP_BIND defaults to 127.0.0.1 and
#   Caddy serves plain HTTP on loopback only — nothing is exposed off the box. Point
#   clients at  http://127.0.0.1/mcp . Uncomment a profile below to expose the server.
#
# [OPT-IN A] Internal network over VPN — plain HTTP, reached by the server's RAW IP.
#   Uncomment the two lines below. HTTP_BIND is the host interface the listener binds to
#   (0.0.0.0 = all; or pin it to the server's VPN IP for a tighter bind). ALLOW_PLAINTEXT_HTTP
#   is the conscious acknowledgement that bearer tokens are NOT encrypted on the wire — so use
#   this ONLY on a trusted private network you control (reachable solely over VPN), never on an
#   untrusted or public network. Also set ALLOWED_HOSTS (above) to the server IP, and point
#   clients at  http://<server-ip>/mcp .
# HTTP_BIND=0.0.0.0
# ALLOW_PLAINTEXT_HTTP=true
#
# Client-facing port published by Caddy (the port clients put in the URL). Defaults
# to 80 for HTTP and 443 for HTTPS. Caddy always listens on container :80/:443, so
# changing these needs no Caddyfile edit. Example: HTTP_PORT=8080 -> clients use
# http://<server-ip>:8080/mcp. (Do NOT use DOMAIN=:<port> to change the port — only
# HTTP_PORT/HTTPS_PORT do; `docmcp.sh serve` rejects a bare :port DOMAIN.)
# HTTP_PORT=80
# HTTPS_PORT=443
#
# [OPT-IN B] Public / untrusted network — automatic HTTPS via a real hostname.
#   Caddy obtains a cert for DOMAIN and serves HTTPS on 443; :80 redirects to it.
#   Needs the hostname resolvable + reachable for ACME (or a DNS-01 setup). To use it:
#   keep ALLOW_PLAINTEXT_HTTP commented, set HTTP_BIND=0.0.0.0, and set DOMAIN below.
# DOMAIN=docs.example.com
#
# `docmcp.sh serve` refuses to publish plaintext off loopback unless you either set
# DOMAIN (HTTPS) or explicitly opt in with ALLOW_PLAINTEXT_HTTP=true.

# --- Resource bounds (DoS guards for authenticated callers) ---
# Largest `limit` search_docs/semantic_search will honor (requests above are clamped).
MAX_SEARCH_LIMIT=50
# Most bytes read_doc pulls off disk in one call; larger files are truncated.
MAX_READ_BYTES=1048576
# Most lines read_doc returns in one call; the response sets truncated=true if clipped.
MAX_READ_LINES=5000

# Default lifetime for tokens minted by `docmcp.sh token` (e.g. 90d, 12h, never).
# The admin/break-glass token created at setup is non-expiring.
TOKEN_TTL=90d

# Offline Docling model artifacts. The ingest image already bakes this in — the
# vendored models (tracked via Git LFS) are COPY'd to /opt/docling/models. Only
# set this if you run ingestion outside the image and must point at that dir.
# DOCLING_ARTIFACTS_PATH=/opt/docling/models

# build/ingest verify the vendored models and, when broken (LFS pointers, empty
# or truncated files), repair them in place via `git lfs fetch` + re-checkout.
# Set false to make a broken models/ a hard stop instead of auto-downloading.
# LFS_AUTO_REPAIR=true
