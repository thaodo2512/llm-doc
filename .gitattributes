# Version-control the raw/ document corpus.
#
# DEFAULT: everything under raw/ is treated as binary and stored in Git LFS, so
# no binary format can ever slip in as a plain git blob. The exceptions below
# revert text/Markdown/source-code back to normal, diffable git. Scoped to raw/
# so test fixtures and project source are unaffected.

raw/** filter=lfs diff=lfs merge=lfs -text

# Vendored Docling models (binary weights) — stored in Git LFS so a clone pulls
# them with the repo and the build needs no model downloads.
models/** filter=lfs diff=lfs merge=lfs -text

# --- exceptions: keep these as normal, diffable git ---
raw/.gitkeep        !filter !diff !merge text

# docs / prose
raw/**/*.md         !filter !diff !merge text
raw/**/*.markdown   !filter !diff !merge text
raw/**/*.txt        !filter !diff !merge text
raw/**/*.rst        !filter !diff !merge text
raw/**/*.csv        !filter !diff !merge text
raw/**/*.tsv        !filter !diff !merge text

# markup / config (text)
raw/**/*.html       !filter !diff !merge text
raw/**/*.htm        !filter !diff !merge text
raw/**/*.css        !filter !diff !merge text
raw/**/*.json       !filter !diff !merge text
raw/**/*.yaml       !filter !diff !merge text
raw/**/*.yml        !filter !diff !merge text
raw/**/*.toml       !filter !diff !merge text
raw/**/*.ini        !filter !diff !merge text
raw/**/*.xml        !filter !diff !merge text

# source code
raw/**/*.py         !filter !diff !merge text
raw/**/*.js         !filter !diff !merge text
raw/**/*.jsx        !filter !diff !merge text
raw/**/*.ts         !filter !diff !merge text
raw/**/*.tsx        !filter !diff !merge text
raw/**/*.go         !filter !diff !merge text
raw/**/*.rs         !filter !diff !merge text
raw/**/*.java       !filter !diff !merge text
raw/**/*.kt         !filter !diff !merge text
raw/**/*.scala      !filter !diff !merge text
raw/**/*.rb         !filter !diff !merge text
raw/**/*.php        !filter !diff !merge text
raw/**/*.c          !filter !diff !merge text
raw/**/*.h          !filter !diff !merge text
raw/**/*.cpp        !filter !diff !merge text
raw/**/*.hpp        !filter !diff !merge text
raw/**/*.cc         !filter !diff !merge text
raw/**/*.cs         !filter !diff !merge text
raw/**/*.swift      !filter !diff !merge text
raw/**/*.sh         !filter !diff !merge text
raw/**/*.sql        !filter !diff !merge text
