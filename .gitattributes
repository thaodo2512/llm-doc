# Executable shell scripts and container/deploy files MUST keep LF endings so they run
# under bash on Linux / WSL Ubuntu even when the repo is cloned through Windows git
# (core.autocrlf=true would otherwise rewrite them to CRLF and bash fails with
# "\r: command not found"; a CRLF Dockerfile RUN line breaks the same way).
*.sh                 text eol=lf
docker/Dockerfile    text eol=lf
docker/Caddyfile     text eol=lf

# Version-control the raw/ document corpus.
#
# DEFAULT: everything under raw/ is treated as binary and stored in Git LFS, so
# no binary format can ever slip in as a plain git blob. The exceptions below
# revert text/Markdown/source-code back to normal, diffable git. Scoped to raw/
# so test fixtures and project source are unaffected.

raw/** filter=lfs diff=lfs merge=lfs -text

# Vendored Docling models (binary weights) — stored in Git LFS so a clone pulls
# them with the repo and the build needs no model downloads.
models/** filter=lfs diff=lfs merge=lfs -text

# ...but an attributes file must NEVER be an LFS pointer: git reads .gitattributes as
# plain text while checking out, and a pointer makes `git clone` print
# "https://git-lfs.github.com/spec/v1 is not a valid attribute name". The vendored model
# dirs ship their own .gitattributes; keep those (and any nested ones) as normal git.
models/**/.gitattributes !filter !diff !merge text

# Keep vendored LICENSE/NOTICE attribution text under models/ as normal, diffable git so a
# plain clone (without `git lfs pull`) can read the upstream license. Only weights stay in LFS.
models/**/LICENSE*  !filter !diff !merge text
models/**/NOTICE*   !filter !diff !merge text

# --- exceptions: keep these as normal, diffable git ---
raw/.gitkeep        !filter !diff !merge text

# docs / prose
raw/**/*.md         !filter !diff !merge text
raw/**/*.markdown   !filter !diff !merge text
raw/**/*.txt        !filter !diff !merge text
raw/**/*.rst        !filter !diff !merge text
raw/**/*.csv        !filter !diff !merge text
raw/**/*.tsv        !filter !diff !merge text

# markup / config (text)
raw/**/*.html       !filter !diff !merge text
raw/**/*.htm        !filter !diff !merge text
