# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Secrets / local config (never commit)
/.env
/tokens.json

# NOTE: raw/ source documents ARE version-controlled — binary types via Git LFS,
# text/Markdown as normal git (see .gitattributes). Nothing under raw/ is ignored.

# Generated doc store / index / db (local dev)
/var/
*.sqlite
*.sqlite3
*.sqlite-*

# HuggingFace model cache (the vendored models live in /models/, tracked via LFS)
.cache/

# Tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.DS_Store
