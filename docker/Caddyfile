# Reverse proxy: the only exposed entry point. Terminates TLS and forwards to
# the (unpublished) docs-mcp service over the internal compose network.
#
# - DOMAIN=:80 (default)        -> plain HTTP on :80, but the host publishes that
#                                  port on LOOPBACK only (see docker-compose.yml),
#                                  so tokens are never sent in cleartext over the
#                                  network. Use this only for local/dev access.
# - DOMAIN=docs.company.internal -> Caddy obtains/serves automatic HTTPS for it.
#                                  REQUIRED for any network/production exposure so
#                                  bearer tokens travel over TLS, not plaintext.
{$DOMAIN} {
	encode gzip

	# Basic per-token rate limiting (brief §12) needs the caddy-ratelimit plugin,
	# which is not in the stock image. To enable, build a custom Caddy with
	# github.com/mholt/caddy-ratelimit and uncomment:
	#
	# rate_limit {
	#     key    {http.request.header.Authorization}
	#     events 60
	#     window 1m
	# }

	# Optional upload/manage portal (only running when PORTAL_ENABLED): /portal* goes to
	# the separate `portal` service; everything else (/mcp) to the read-only docs-mcp.
	handle /portal* {
		reverse_proxy portal:8080
	}
	handle {
		reverse_proxy docs-mcp:8080
	}
}
